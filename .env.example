TRANSCODES_BACKEND_URL=http://localhost:3500
# Member MCP JWT — oid, pid, mid, aud=transcodes-mcp, exp, ...
# Sent on every request as the x-transcodes-token header.
TRANSCODES_TOKEN=
# Required JSON map: MCP tool name → path after /v1. Only listed tools are exposed; add entries for the tools you use.
TRANSCODES_BACKEND_ENDPOINTS={"get_project":"/project"}
