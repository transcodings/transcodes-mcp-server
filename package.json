{
  "name": "@bigstrider/transcodes-mcp-server",
  "version": "1.3.0",
  "description": "stdio MCP server that proxies HTTP requests to Transcodes API with a member MCP JWT (x-transcodes-token header)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "transcodes-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "release-package": "npm run build && npx changeset publish"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "axios": "^1.13.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "transcodes",
    "proxy"
  ],
  "author": "bigstrider",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
